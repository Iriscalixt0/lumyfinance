{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/main.tsx", "src/App.tsx", "src/vite-env.d.ts", "src/lib/i18n.tsx", "src/lib/product-config.ts", "src/lib/utils/**/*", "src/types/**/*", "src/hooks/**/*", "src/pages/**/*", "src/components/theme-provider.tsx", "src/components/logo.tsx", "src/components/locale-switcher.tsx", "src/components/landing/LandingPage.tsx", "src/components/plan/plan-card.tsx", "vite.config.ts"],
  "exclude": ["node_modules"]
}
