# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
# Em produção: use o domínio público (ex: https://seudominio.com.br)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase Auth:
# 1) Confirmar e-mail (obrigatório para o app enviar o e-mail de confirmação):
#    Dashboard > Authentication > Providers > Email > ative "Confirm email".
# 2) Redirect URLs (Authentication > URL Configuration > Redirect URLs):
#    - http://localhost:3000/api/auth/callback  (dev)
#    - https://seudominio.com/api/auth/callback (produção)
#    Ou use wildcard: http://localhost:3000/** e https://seudominio.com/**

# Stripe (produção)
# Crie produtos/preços no Stripe Dashboard e cole os IDs dos preços aqui
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
STRIPE_PRICE_PRO_USD=price_xxx
STRIPE_PRICE_BUSINESS_USD=price_xxx
# Preços Pro por moeda (checkout por país)
STRIPE_PRICE_PRO_CAD=price_xxx
STRIPE_PRICE_PRO_GBP=price_xxx
STRIPE_PRICE_PRO_EUR=price_xxx
STRIPE_PRICE_PRO_CHF=price_xxx
STRIPE_PRICE_PRO_SGD=price_xxx
STRIPE_PRICE_PRO_AUD=price_xxx
STRIPE_PRICE_PRO_MXN=price_xxx
STRIPE_PRICE_PRO_SEK=price_xxx
STRIPE_PRICE_PRO_NOK=price_xxx
STRIPE_PRICE_PRO_DKK=price_xxx
STRIPE_PRICE_PRO_CNY=price_xxx
STRIPE_PRICE_PRO_HKD=price_xxx
STRIPE_PRICE_PRO_ILS=price_xxx

# Cron (Vercel Cron - protege /api/cron/*)
CRON_SECRET=your_cron_secret
DISCORD_HEALTH_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Beta conversion channels (optional)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Equipe Lumyf <noreply@lumyf.com>
WHATSAPP_API_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Beta admin: emails separados por vírgula (ex: graphyx.ai@gmail.com)
BETA_ADMIN_EMAILS=

# Test admin (optional)
ADMIN_TEST_EMAIL=admin@example.com
ADMIN_TEST_PASSWORD=change_me
